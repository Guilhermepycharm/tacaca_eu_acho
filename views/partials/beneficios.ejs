<section class="beneficios" id="beneficios">
  <div class="container">
    <div class="beneficios__header">
      <p class="section-label reveal">Ciência & Tradição</p>
      <h2 class="section-title reveal"><%= content.beneficios.title %></h2>
      <p class="section-subtitle reveal"><%= content.beneficios.subtitle %></p>
    </div>
    <div class="beneficios__grid">
      <% content.beneficios.cards.forEach((card, i) => { %>
        <div class="beneficio-card reveal reveal-delay-<%= (i % 3) + 1 %>">
          <div class="beneficio-card__icon">
            <svg viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <% if (card.icon === 'nutrient') { %>
                <circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/>
              <% } else if (card.icon === 'leaf') { %>
                <path d="M17 8C8 10 5.9 16.17 3.82 21.34l1.89-.82L8 21l2-3c4-2 6-5 6-9z"/><path d="M2 2s7 3 10 8"/>
              <% } else if (card.icon === 'protein') { %>
                <path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/>
              <% } else if (card.icon === 'fire') { %>
                <path d="M12 2c.5 2.5 2 4.5 2 7a4 4 0 1 1-8 0c0-2.5 2-5 2-7 1 1 2.5 2 4 0z"/>
              <% } else if (card.icon === 'gut') { %>
                <path d="M12 2a7 7 0 0 1 7 7c0 3-2 5-3 7s-1 4-1 4"/><path d="M12 2a7 7 0 0 0-7 7c0 3 2 5 3 7s1 4 1 4"/>
              <% } else if (card.icon === 'history') { %>
                <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
              <% } %>
            </svg>
          </div>
          <h3><%= card.title %></h3>
          <p><%= card.text %></p>
        </div>
      <% }) %>
    </div>
  </div>
</section>
